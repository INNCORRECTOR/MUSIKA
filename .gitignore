# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Environment and secrets (never commit)
.env
.env.*
!.env.example

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checkers & linters
.mypy_cache/
.ruff_cache/

# Logs and local databases
*.log
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Editors (optional — remove if your team commits shared settings)
.idea/
